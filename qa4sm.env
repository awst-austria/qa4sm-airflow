### CUSTOM ENVIRONMENT VARIABLES USED IN DAG RUNS
QA4SM_DATA_PATH="/qa4sm/data"                                       # ROOT directory where the data is stored
QA4SM_IP_OR_URL="test.qa4sm.eu"                                     # QA4SM API contact address or IP
QA4SM_PORT_OR_NONE="None"                                           # QA4SM API contact port (for IP) or None (for URL)
QA4SM_API_TOKEN="2b37740a1f6733c9cfc2e1e105abe974ff8c4204"          # QA4SM API token with sufficient privileges

# C3S SM API
CDS_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"                    # Token to download data from https://cds.climate.copernicus.eu/
C3S_SM_DAG_IMAGE="ghcr.io/tuw-geo/c3s_sm:v0.3.2"                    # Pull-able image that contains the code for C3S_SM DAGs (usually `latest`)
ERA_DAG_IMAGE="ghcr.io/tuw-geo/ecmwf_models:v0.11.0"                # Pull-able image that contains the code for ERA DAGs (usually `latest`)

# SMOS L2 API
DISSEO_USERNAME="wolfgang.preimesberger@geo.tuwien.ac.at"           # Username to download SMOS L2 from FTP. Account at https://eoiam-idp.eo.esa.int
DISSEO_PASSWORD="xxxxxxxxxxx"                                       # Password to download SMOS L2 from FTP. Account at https://eoiam-idp.eo.esa.int
SMOS_DAG_IMAGE="ghcr.io/tuw-geo/smos:v0.3.2"                        # Pull-able image that contains the code for SMOS DAGs (usually `latest`)

#setup.cfg console scripts, cli file
# SMAP L3 API
SMAP_USERNAME="tunterho"                                            # Username to download SMOS L2 from FTP. Account at https://eoiam-idp.eo.esa.int
SMAP_PASSWORD="xxxxxxxxxxxxxxx"                                     # Password to download SMOS L2 from FTP. Account at https://eoiam-idp.eo.esa.int
SMAP_DAG_IMAGE="ghcr.io/tuw-geo/smap_io:v0.8"
